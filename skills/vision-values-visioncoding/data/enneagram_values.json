    "2": {"label_en": "The Helper",       "label_ko": "조력자",       "world": "봉사·아웃리치·사랑으로 따뜻한 세상",                  "values": ["Love", "Mercy", "Service", "Brotherly Kindness", "Compassion", "Hospitality", "Sacrifice"], "wings": [1, 3]},
    "3": {"label_en": "The Achiever",     "label_ko": "성취가",       "world": "다양성·성공을 통한 우수성의 세상",                    "values": ["Excellence", "Vision", "Achievement", "Stewardship", "Diligence", "Recognition", "Productivity"], "wings": [2, 4]},
    "4": {"label_en": "The Individualist","label_ko": "개인주의자",   "world": "자유로운 자기표현·예술이 격려되는 아름다운 세상",      "values": ["Beauty", "Creativity", "Authenticity", "Self-Expression", "Depth", "Originality", "Sensitivity"], "wings": [3, 5]},
    "5": {"label_en": "The Investigator", "label_ko": "탐구가",       "world": "흥미로운 지적 탐구로 끊임없이 진화하는 창의적 세상",  "values": ["Knowledge", "Wisdom", "Discernment", "Creativity", "Truth", "Curiosity", "Independence"], "wings": [4, 6]},
    "6": {"label_en": "The Loyalist",     "label_ko": "충성가",       "world": "다양한 공동체가 서로 신뢰하는 안전한 세상",            "values": ["Faithfulness", "Loyalty", "Community", "Security", "Trust", "Vigilance", "Reliability"], "wings": [5, 7]},
    "7": {"label_en": "The Enthusiast",   "label_ko": "열정가",       "world": "새로움이 살아있고 흥미롭고 재미있는 세상",            "values": ["Joy", "Adventure", "Freedom", "Hope", "Vitality", "Curiosity", "Optimism"], "wings": [6, 8]},
    "8": {"label_en": "The Challenger",   "label_ko": "도전가",       "world": "강하고 독립적이며 질서·권력이 있는 세상",              "values": ["Strength", "Courage", "Justice", "Authority", "Stewardship", "Protection", "Decisiveness"], "wings": [7, 9]},
    "9": {"label_en": "The Peacemaker",   "label_ko": "평화주의자",   "world": "절제와 균형의 평화로운 세상",                          "values": ["Peace", "Harmony", "Humility", "Patience", "Reconciliation", "Acceptance", "Stability"], "wings": [8, 1]}
